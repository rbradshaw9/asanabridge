// AsanaBridge v2.3.0 — Clean Prisma Schema
// Removed: SocialAccount, AuthProvider enum, SignupMethod enum,
//          avatar, emailVerified, monthlyTasksUsed, lastUsageReset
// Added:   AppSession (DB-backed app auth sessions)
//          AgentCommand (implemented command queue)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserPlan {
  FREE
  PRO
  ENTERPRISE
}

enum SyncDirection {
  ASANA_TO_OF
  OF_TO_ASANA
  BIDIRECTIONAL
}

enum SyncStatus {
  PENDING
  RUNNING
  SUCCESS
  ERROR
}

enum SupportCategory {
  GENERAL
  TECHNICAL
  BILLING
  FEATURE
  BUG
}

enum SupportPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING
  CLOSED
}

enum AppSessionStatus {
  PENDING
  AUTHORIZED
  EXPIRED
}

enum AgentCommandType {
  CREATE_TASK
  UPDATE_TASK
  DELETE_TASK
  COMPLETE_TASK
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  // password is nullable: allows future social auth without breaking existing users
  password    String?
  name        String?
  plan        UserPlan  @default(FREE)
  isAdmin     Boolean   @default(false)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  asanaToken     AsanaToken?
  omnifocusSetup OmniFocusSetup?
  syncMappings   SyncMapping[]
  syncLogs       SyncLog[]
  supportTickets SupportTicket[]
  appSessions    AppSession[]

  @@map("users")
}

model AsanaToken {
  id           String    @id @default(cuid())
  userId       String    @unique
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("asana_tokens")
}

model OmniFocusSetup {
  id        String   @id @default(cuid())
  userId    String   @unique
  agentKey  String   @unique
  isActive  Boolean  @default(false)
  version   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  commands AgentCommand[]

  @@map("omnifocus_setups")
}

model AgentCommand {
  id           String           @id @default(cuid())
  setupId      String
  type         AgentCommandType
  payload      Json
  acknowledged Boolean          @default(false)
  createdAt    DateTime         @default(now())
  acknowledgedAt DateTime?

  setup OmniFocusSetup @relation(fields: [setupId], references: [id], onDelete: Cascade)

  @@index([setupId, acknowledged])
  @@map("agent_commands")
}

model AppSession {
  id        String           @id @default(cuid())
  userId    String?          // null until authorized
  token     String?          // JWT token, set when authorized
  status    AppSessionStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, expiresAt])
  @@map("app_sessions")
}

model SyncMapping {
  id               String   @id @default(cuid())
  userId           String
  asanaProjectId   String
  asanaProjectName String
  ofProjectName    String
  isActive         Boolean  @default(true)
  lastSyncAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncLogs SyncLog[]

  @@unique([userId, asanaProjectId])
  @@index([userId, isActive])
  @@map("sync_mappings")
}

model SyncLog {
  id            String        @id @default(cuid())
  userId        String
  syncMappingId String
  direction     SyncDirection @default(BIDIRECTIONAL)
  status        SyncStatus
  itemsSynced   Int           @default(0)  @map("itemssynced")
  errorMessage  String?
  createdAt     DateTime      @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncMapping SyncMapping @relation(fields: [syncMappingId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([syncMappingId, createdAt(sort: Desc)])
  @@map("sync_logs")
}

model SupportTicket {
  id       String              @id @default(cuid())
  userId   String
  name     String
  email    String
  subject  String
  category SupportCategory     @default(GENERAL)
  priority SupportPriority     @default(NORMAL)
  status   SupportTicketStatus @default(OPEN)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses SupportTicketResponse[]

  @@index([userId])
  @@index([status])
  @@map("support_tickets")
}

model SupportTicketResponse {
  id         String   @id @default(cuid())
  ticketId   String
  message    String
  isFromUser Boolean  @default(true)
  createdAt  DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("support_ticket_responses")
}
