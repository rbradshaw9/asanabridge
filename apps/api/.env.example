# ── Required ───────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/asanabridge?schema=public"
JWT_SECRET="your-super-secret-jwt-key-must-be-at-least-32-characters-long"

# ── Server ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3001

# ── URLs ───────────────────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"
BACKEND_URL="http://localhost:3001"

# ── Asana OAuth ────────────────────────────────────────────────────────────────
ASANA_CLIENT_ID=""
ASANA_CLIENT_SECRET=""
ASANA_REDIRECT_URI="http://localhost:3001/api/oauth/asana/callback"

# ── Downloads (Cloudflare R2 or any public URL) ───────────────────────────────
DOWNLOAD_BASE_URL="https://your-r2-bucket.r2.cloudflarestorage.com"

# ── Optional ───────────────────────────────────────────────────────────────────
JWT_EXPIRES_IN="7d"
